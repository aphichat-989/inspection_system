# Django runtime environment; use production for Docker and server deployments.
DJANGO_ENV=production

# Enables Django debug output; keep false outside local development.
DJANGO_DEBUG=false

# Legacy compatibility alias for Django debug output.
DEBUG=false

# Secret signing key for Django sessions and security features.
DJANGO_SECRET_KEY=CHANGE_ME

# Comma-separated hostnames or IPs that may serve this site.
ALLOWED_HOSTS=*

# Optional comma-separated HTTPS origins trusted for unsafe CSRF requests.
DJANGO_CSRF_TRUSTED_ORIGINS=

# Redirect all HTTP requests to HTTPS when TLS is terminated by Django or a proxy.
DJANGO_SECURE_SSL_REDIRECT=false

# Mark the session cookie as HTTPS-only.
DJANGO_SESSION_COOKIE_SECURE=false

# Mark the CSRF cookie as HTTPS-only.
DJANGO_CSRF_COOKIE_SECURE=false

# HTTP Strict Transport Security duration in seconds; use 0 to disable.
DJANGO_SECURE_HSTS_SECONDS=0

# Include subdomains in the HSTS policy.
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false

# Allow the domain to be submitted to browser HSTS preload lists.
DJANGO_SECURE_HSTS_PRELOAD=false

# Trust X-Forwarded-Proto from a reverse proxy for HTTPS detection.
DJANGO_USE_X_FORWARDED_PROTO=true

# PostgreSQL database name created by Docker Compose.
DB_NAME=inspection_system

# PostgreSQL username created by Docker Compose.
DB_USER=inspection_user

# PostgreSQL password created by Docker Compose.
DB_PASSWORD=CHANGE_ME

# PostgreSQL hostname used by Django inside Docker Compose.
DB_HOST=db

# PostgreSQL port used by Django.
DB_PORT=5432

# Seconds the startup script waits for PostgreSQL before failing.
DB_WAIT_TIMEOUT=60

# Persistent PostgreSQL connection lifetime in seconds.
DB_CONN_MAX_AGE=60

# PostgreSQL SSL mode for Django database connections.
DB_SSLMODE=prefer

# Number of Gunicorn worker processes.
GUNICORN_WORKERS=3

# Gunicorn worker timeout in seconds.
GUNICORN_TIMEOUT=120

# Gunicorn log level.
GUNICORN_LOG_LEVEL=info
