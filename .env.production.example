# Copy this file to .env.production on the server and replace every CHANGE_ME value.
# Do not commit .env.production because it contains real deployment secrets.

# Django runtime environment.
DJANGO_ENV=production

# Keep debug disabled in production.
DJANGO_DEBUG=false
DEBUG=false

# Replace with a long random value before deployment.
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET

# Replace with the real comma-separated production hostnames or server IPs.
ALLOWED_HOSTS=SERVER_IP,example.com

# Optional comma-separated trusted origins, for example http://SERVER_IP:8000.
DJANGO_CSRF_TRUSTED_ORIGINS=

# HTTPS is not forced by default. Enable after TLS/reverse proxy is ready.
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_USE_X_FORWARDED_PROTO=true

# PostgreSQL connection used by Django and Docker Compose.
# Replace DB_PASSWORD with a strong server-only password.
DB_NAME=inspection_system
DB_USER=inspection_user
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
DB_HOST=db
DB_PORT=5432
DB_WAIT_TIMEOUT=60
DB_CONN_MAX_AGE=60
DB_SSLMODE=prefer

# Gunicorn runtime tuning.
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# Host port bindings. Use 127.0.0.1 behind a reverse proxy, or 0.0.0.0 for direct LAN access.
APP_BIND_IP=127.0.0.1
APP_PORT=8000

# pgAdmin is started only with the admin profile.
# Replace PGADMIN_DEFAULT_EMAIL and PGADMIN_DEFAULT_PASSWORD before enabling the admin profile.
PGADMIN_BIND_IP=127.0.0.1
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG_PGADMIN_PASSWORD

# Backup and restore script settings.
COMPOSE_FILE=docker-compose.production.yml
ENV_FILE=.env.production
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
